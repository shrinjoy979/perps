// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id       @default(uuid())
  username      String
  password      String

  orders        Order[]
  makerFills    Fill[]      @relation("maker_user")
  takerFills    Fill[]      @relation("taker_user")
}

model Market {
  id        String      @id       @default(uuid())
  slug      String
  imageUrl  String
}

model Order {
  id              String      @id       @default(uuid())
  userId          String
  marketId        String
  orderType       orderType
  side            Side
  price           String
  slippage        Int
  qty             String
  initialMargin   String
  filledQty       String
  status          orderStatus
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  maker_fills     Fill[]      @relation("maker")
  taker_fills     Fill[]      @relation("taker")
  user            User        @relation(fields: [userId], references: [id])
}

model Fill {
  id              String      @id       @default(uuid())
  makerId         String
  takerId         String
  qty             String
  price           String
  makerOrderId    String
  takerOrderId    String
  marketId        String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  taker_order     Order       @relation("taker", fields: [makerOrderId], references: [id])
  maker_order     Order       @relation("maker", fields: [takerOrderId], references: [id])
  taker_user      User        @relation("taker_user", fields: [takerId], references: [id])
  maker_user      User        @relation("maker_user", fields: [makerId], references: [id])
}

enum orderStatus {
  Filled
  PartiallyFilled
  Cancelled
  Open
}

enum Side {
  Bid
  Ask
}

enum orderType {
  Market
  Limit
}
